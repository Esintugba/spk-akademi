{
  "Jwt": {
    "Key": "SPK_Akademi_Super_Secret_Key_2026_123456789",
    "Issuer": "spk-api",
    "Audience": "spk-client"
  },
  "Database": {
    "Provider": "Sqlite",
    "AutoMigrate": true
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "PermitLimit": 120,
    "QueueLimit": 0,
    "WindowSeconds": 60
  },
  "BackgroundQueues": {
    "ImportCapacity": 100,
    "ContactCapacity": 500
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/spk-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Branding": {
    "AppName": "SPK Akademi",
    "SupportEmail": "esintugbad@gmail.com",
    "ApiTitle": "SPK Akademi API"
  },
  "Billing": {
    "PaymentsEnabled": false
  },
  "Seo": {
    "PublicBaseUrl": "https://spkakademi.com",
    "DefaultImageUrl": "/social-preview.svg",
    "SitemapCacheMinutes": 30
  },
  "Email": {
    "AdminNotificationAddress": "esintugbad@gmail.com"
  },
  "Onboarding": {
    "DemoLicenseName": "SPK Düzey 1 Demo",
    "DemoLicenseSlug": "spk-duzey-1-demo",
    "DemoDurationDays": 7,
    "AutoGrantDemoOnRegister": true,
    "CreateDemoLicenseIfMissing": true,
    "DemoLimits": {
      "MaxQuestionsPerDay": 50,
      "MaxTrialAttempts": 3,
      "ReadonlyAnalytics": true,
      "LockPremiumFeatures": true
    }
  }
}
